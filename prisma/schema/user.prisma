model User {
    id             String          @id @default(cuid())
    email          String          @unique
    name           String
    password       String
    role           Role            @default(CUSTOMER)
    status         UserStatus      @default(ACTIVE)
    createdAt      DateTime        @default(now())
    vendorProfile  VendorProfile?
    orders         Order[]
    communityPosts CommunityPost[]

    @@map("users")
}
